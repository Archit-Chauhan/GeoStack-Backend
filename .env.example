# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- Database ----
# Atlas: mongodb+srv://<user>:<password>@<cluster>/geostock
# Local: mongodb://127.0.0.1:27017/geostock
MONGO_URI=mongodb://127.0.0.1:27017/geostock

# ---- CORS / client origin ----
CLIENT_URL=http://localhost:5173

# ---- JWT (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))") ----
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_REFRESH_TTL=7d
COOKIE_SECRET=replace-with-another-random-string

# ---- Optional / future (app runs without these) ----
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# CLOUDINARY_URL=
